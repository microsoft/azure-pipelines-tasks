{
    "common": [
        {
            "module": "../Common/Sanitizer",
            "type": "ps"
        }
    ],
    "externals": {
       "nugetv2": [
            {
                "name": "TaskModuleSqlUtility",
                "version": "0.1.7",
                "repository": "https://pkgs.dev.azure.com/mseng/PipelineTools/_packaging/PipelineTools_PublicPackages/nuget/v2",
                "cp": [
                    {
                      "source": "*.ps*",
                      "dest":"ps_modules/TaskModuleSqlUtility"
                    }
                ]
            },
            {
                "name": "VstsTaskSdk",
                "version": "0.21.0",
                "repository": "https://pkgs.dev.azure.com/mseng/PipelineTools/_packaging/PipelineTools_PublicPackages/nuget/v2",
                "cp": [
                    {
                        "source": [
                            "*.dll",
                            "*.ps1",
                            "*.psd1",
                            "*.psm1",
                            "lib.json",
                            "Strings"
                        ],
                        "dest": "ps_modules/VstsTaskSdk/",
                        "options": "-R"
                    }
                ]
            }
        ]
    },
    "cp": [
        {
            "source": [
                "*.sql"
            ]
        }
    ]
}