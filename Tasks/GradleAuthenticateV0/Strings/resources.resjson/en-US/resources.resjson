{
  "loc.friendlyName": "Gradle Authenticate (Test)",
  "loc.helpMarkDown": "[Learn more about this task](https://aka.ms/gradle-authenticate)",
  "loc.description": "Authenticate Gradle builds against Azure Artifacts feeds using Workload Identity Federation or a user-provided access token.",
  "loc.instanceNameFormat": "Gradle Authenticate",
  "loc.input.label.buildFiles": "Build files",
  "loc.input.help.buildFiles": "Newline-separated list of Gradle build files to scan for pkgs.dev.azure.com URLs. Should include settings.gradle for plugin version discovery.",
  "loc.input.label.repositoryUrl": "Repository URL(s)",
  "loc.input.help.repositoryUrl": "Newline-separated list of explicit Azure Artifacts repository URLs to authenticate, in addition to any discovered from build files. Supports both dependency feeds and plugin repositories.",
  "loc.input.label.adoServiceConnection": "Service connection",
  "loc.input.help.adoServiceConnection": "Azure DevOps service connection for Workload Identity Federation (WIF). If omitted, the user must provide an access token via the ARTIFACTS_GRADLE_AUTH_ACCESS_TOKEN environment variable.",
  "loc.input.label.pluginToolVersion": "Plugin tool version",
  "loc.input.help.pluginToolVersion": "Override the credprovider plugin version used for the local JAR layout and init script. Use when settings.gradle does not declare the plugin or when version resolution fails.",
  "loc.input.label.gradleUserHome": "Gradle user home",
  "loc.input.help.gradleUserHome": "Override the Gradle user home directory. Defaults to ~/.gradle. The init script is written to <gradleUserHome>/init.d/.",
