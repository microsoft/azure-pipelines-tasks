{
  "loc.friendlyName": "Azure Database for MySQL 部署",
  "loc.helpMarkDown": "[了解有关此任务的详细信息](https://github.com/microsoft/azure-pipelines-tasks/blob/master/Tasks/AzureMysqlDeploymentV2/README.md)",
  "loc.description": "运行脚本并对 Azure Database for MySQL 灵活服务器进行更改",
  "loc.instanceNameFormat": "执行 Azure MySQL: $(TaskNameSelector)",
  "loc.releaseNotes": "版本 2.0 的新增功能:\n- Azure Database for MySQL 灵活服务器支持(替换即将停用的单一服务器)。\n- 面向 Microsoft.DBforMySQL/flexibleServers 的新自定义 ARM 客户端(API 2024-12-30)。\n- 本机 MySQL 身份验证 - 用户名无需 @servername 后缀。\n- 通过 stdin 管道的可靠 SQL 文件执行(替换损坏的 'source' 命令)。\n- 使用指数回退轮询创建异步防火墙规则(处理 202 个响应)。\n- 通过 nextLink 提供服务器列表分页支持。\n- 迁移: 更新管道以使用 AzureMysqlDeployment@2、使用灵活服务器 FQDN 以及从 SqlUsername 中移除 @servername。",
  "loc.group.displayName.target": "DB 详细信息",
  "loc.group.displayName.taskDetails": "部署包",
  "loc.group.displayName.firewall": "防火墙",
  "loc.input.label.ConnectedServiceName": "Azure 订阅",
  "loc.input.help.ConnectedServiceName": "这是连接到 Azure 帐户所必需的。<br>要配置新的服务连接，请从列表中选择 Azure 订阅，然后单击“授权”。<br>如果未列出订阅，或希望使用现有服务主体，可使用“添加”或“管理”按钮设置 Azure 服务连接。",
  "loc.input.label.ServerName": "主机名",
  "loc.input.help.ServerName": "“Azure Database for MySQL 灵活服务器”的服务器名称。例如 fabrikam.mysql.database.azure.com。使用 MySQL Workbench 连接时，该值与“参数”中的“主机名”所用的值相同。",
  "loc.input.label.DatabaseName": "数据库名称",
  "loc.input.help.DatabaseName": "数据库的名称。如果已有数据库，则需要在该数据库上运行以下脚本。否则，可使用脚本本身创建数据库。",
  "loc.input.label.SqlUsername": "服务器管理员登录名",
  "loc.input.help.SqlUsername": "Azure Database for MySQL 灵活服务器支持本机 MySQL 身份验证。可使用服务器的管理员登录名连接并向服务器进行身份验证。示例: bbo1。使用 MySQL Workbench 连接时，该值与“参数”中的“用户名”所用的值相同。",
  "loc.input.label.SqlPassword": "密码",
  "loc.input.help.SqlPassword": "Azure Database for MySQL 的管理员密码。如果不撤回密码，则可以通过 [Azure 门户](https://learn.microsoft.com/azure/mysql/flexible-server/how-to-manage-server-portal)更改密码。<br>它可以是在管道中定义的变量。示例: $(password)。<br>还可以将变量类型标记为 'secret' 来保护它。",
  "loc.input.label.TaskNameSelector": "类型",
  "loc.input.help.TaskNameSelector": "选择“脚本文件”与“内联脚本”中的一个选项。",
  "loc.input.label.SqlFile": "MySQL 脚本",
  "loc.input.help.SqlFile": "自动化代理或自动化代理可访问的 UNC 路径(如 \\\\\\\\BudgetIT\\DeployBuilds\\script.sql)上的脚本文件的完整路径。此外，还可在此处使用预定义的系统变量，如 $(agent.releaseDirectory)。可在此处使用包含 SQL 语句的文件。",
  "loc.input.label.SqlInline": "内联 MySQL 脚本",
  "loc.input.help.SqlInline": "输入要在上方所选的数据库上执行的 MySQL 脚本。",
  "loc.input.label.SqlAdditionalArguments": "其他 MySQL 参数",
  "loc.input.help.SqlAdditionalArguments": "MySQL 简单 SQL shell 支持的其他选项。 在 Azure Database for MySQL 上执行给定文件时，将应用这些选项。<br>例如: 可以将默认制表符分隔输出格式更改为 HTML 甚至 XML 格式。或者，如果由于大型结果集的内存不足而出现问题，可使用 --quick 选项。",
  "loc.input.label.IpDetectionMethod": "使用以下方法指定防火墙规则",
  "loc.input.help.IpDetectionMethod": "要成功执行任务，需要支持管理员从自动化代理的 IP 地址访问 Azure Database for MySQL 灵活服务器。<br>通过选择自动检测，可以自动为自动化代理的可能 IP 地址范围添加防火墙例外项，否则可以显式指定范围。",
  "loc.input.label.StartIpAddress": "起始 IP 地址",
  "loc.input.help.StartIpAddress": "自动化代理计算机池的起始 IP 地址，如 196.21.30.50。",
  "loc.input.label.EndIpAddress": "结束 IP 地址",
  "loc.input.help.EndIpAddress": "自动化代理计算机池的结束 IP 地址，如 196.21.30.65。",
  "loc.input.label.DeleteFirewallRule": "在任务结束后删除规则",
  "loc.input.help.DeleteFirewallRule": "如果选择，将为相应的 Azure Database for MySQL 移除添加的自动化代理 IP 地址例外项。",
