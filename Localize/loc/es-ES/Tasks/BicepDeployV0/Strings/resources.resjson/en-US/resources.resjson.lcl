          <Tgt Cat="Text" Stat="Loc" Orig="New">
            <Val><![CDATA[Especifica la operación que se va a realizar. La implementación admite: crear, validar, whatIf. La pila de implementación admite: crear, validar, eliminar.]]></Val>
          </Tgt>
        </Str>
        <Disp Icon="Str" />
      </Item>
      <Item ItemId=";loc.input.help.parameters" ItemType="0" PsrId="306" Leaf="true">
