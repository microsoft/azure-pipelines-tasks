      <Item ItemId=";loc.messages.Debug_UsingBuildServiceCreds" ItemType="0" PsrId="306" Leaf="true">
        <Str Cat="Text">
          <Val><![CDATA[Using build service credentials for authentication]]></Val>
          <Tgt Cat="Text" Stat="Loc" Orig="New">
