          <Val><![CDATA[The MySQL Flexible Server list is empty. The MySQL server host name is invalid.]]></Val>
          <Tgt Cat="Text" Stat="Loc" Orig="New">
            <Val><![CDATA[La lista de servidores flexibles de MySQL está vacía. El nombre de host del servidor MySQL no es válido.]]></Val>
          </Tgt>
        </Str>
        <Disp Icon="Str" />
      </Item>
      <Item ItemId=";loc.messages.EndIpAddressCannotBeEmpty" ItemType="0" PsrId="306" Leaf="true">
        <Str Cat="Text">
          <Val><![CDATA[The end IP address of the firewall rule cannot be null.]]></Val>
          <Tgt Cat="Text" Stat="Loc" Orig="New">
