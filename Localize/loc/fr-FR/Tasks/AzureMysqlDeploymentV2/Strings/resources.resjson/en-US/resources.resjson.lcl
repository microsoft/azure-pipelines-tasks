      <Item ItemId=";loc.messages.ARGD_ConstructorFailed" ItemType="0" PsrId="306" Leaf="true">
        <Str Cat="Text">
          <Val><![CDATA[The task failed while initializing. Error: %s .]]></Val>
          <Tgt Cat="Text" Stat="Loc" Orig="New">
