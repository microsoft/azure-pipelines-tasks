        <Disp Icon="Str" />
      </Item>
      <Item ItemId=";loc.input.help.operation" ItemType="0" PsrId="306" Leaf="true">
        <Str Cat="Text">
          <Val><![CDATA[Specifies the operation to perform. Deployment supports: create, validate, whatIf. Deployment Stack supports: create, validate, delete.]]></Val>
          <Tgt Cat="Text" Stat="Loc" Orig="New">
            <Val><![CDATA[Gibt den auszuführenden Vorgang an. Bereitstellung unterstützt: create, validate, whatif. Bereitstellungsstapel unterstützt: create, validate, delete.]]></Val>
          </Tgt>
        </Str>
        <Disp Icon="Str" />
      </Item>
      <Item ItemId=";loc.input.help.parameters" ItemType="0" PsrId="306" Leaf="true">
        <Str Cat="Text">
