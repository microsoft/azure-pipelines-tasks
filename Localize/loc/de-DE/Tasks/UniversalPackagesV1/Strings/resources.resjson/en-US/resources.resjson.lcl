      <Item ItemId=";loc.messages.Error_AuthenticationFailed" ItemType="0" PsrId="306" Leaf="true">
        <Str Cat="Text">
          <Val><![CDATA[Unable to authenticate for Universal Packages operations. Ensure the task runs in an Azure Pipelines build/release or provide a valid service connection.]]></Val>
          <Tgt Cat="Text" Stat="Loc" Orig="New">
            <Val><![CDATA[Die Authentifizierung für Universal Packages-Vorgänge ist nicht möglich. Stellen Sie sicher, dass die Aufgabe in einem Azure Pipelines-Build oder -Release ausgeführt wird, oder geben Sie eine gültige Dienstverbindung an.]]></Val>
          </Tgt>
        </Str>
        <Disp Icon="Str" />
