      <Item ItemId=";loc.input.help.actionOnUnmanageManagementGroups" ItemType="0" PsrId="306" Leaf="true">
        <Str Cat="Text">
          <Val><![CDATA[Specifies the action to take on management groups not defined in the template.]]></Val>
          <Tgt Cat="Text" Stat="Loc" Orig="New">
